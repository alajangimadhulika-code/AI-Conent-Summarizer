# Example environment variables for AI Content Summarizer
# Copy this file to `.env` and fill in your values (do NOT commit `.env`)

# Groq API Configuration
# Get your API key from: https://console.groq.com/keys
GROQ_API_KEY=your_groq_api_key_here

# Groq Model Selection
# Recommended options: mixtral-8x7b-32768, llama3-8b-8192, gemma-7b-it
GROQ_MODEL=mixtral-8x7b-32768

# Other optional settings
# PAGE_CONFIG and other app settings are in config.py